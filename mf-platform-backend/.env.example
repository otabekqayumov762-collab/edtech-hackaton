DEBUG=True
SECRET_KEY=change-me-in-prod
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5180,https://mf-platform-sigma.vercel.app

# Postgres
DB_NAME=mfplatform
DB_USER=mfuser
DB_PASSWORD=mfpass
DB_HOST=localhost
DB_PORT=5432

# Devda Postgres bo'lmasa SQLite ishlatish (1/true/yes — yoqadi).
USE_SQLITE=False

# Production HTTPS: True bo'lsa Django barcha HTTP'ni HTTPS'ga yo'naltiradi.
# Faqat DEBUG=False holatda kuchga kiradi.
SECURE_SSL_REDIRECT=True

# API hujjatlari (/api/schema, /api/docs, /api/redoc). Default: DEBUG qiymati.
# Production'da yoqish uchun aniq True qiling.
EXPOSE_API_DOCS=False

# Groq LLM — AI Assistant. https://console.groq.com/keys dan oling.
# Kalit bo'lmasa AI repetitor va motivatsion notification'lar fallback template'ga tushadi.
# So'rov timeout'i: 8 soniya (ai_assistant/services.py va notifications/services.py).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
